{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CS Resource Hub",
  "description": "Schema for a single resource entry",
  "type": "object",
  "required": [
    "id",
    "name",
    "url",
    "description",
    "category",
    "cost",
    "status",
    "region",
    "quality",
    "source",
    "date_added"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "url": {
      "type": "string",
      "pattern": "^https://.+"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 120
    },
    "category": {
      "type": "string",
      "enum": [
        "learning-resources",
        "communities",
        "clubs",
        "volunteer",
        "ctfs",
        "competitions",
        "hackathons",
        "game-jams",
        "projects",
        "repositories",
        "open-source-help",
        "research",
        "conferences",
        "fellowships",
        "online-events",
        "career-fairs",
        "scholarships",
        "startup-programs",
        "freelance",
        "certifications",
        "free-benefits"
      ]
    },
    "cost": {
      "type": "string",
      "enum": ["free", "freemium", "paid"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "archived"]
    },
    "region": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "quality": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "source": {
      "type": "string",
      "enum": ["official-website", "community", "research", "social-media"]
    },
    "date_added": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "deadline": {
      "type": "string",
      "enum": [
        "January",
        "February",
        "March",
        "April",
        "May",
        "June",
        "July",
        "August",
        "September",
        "October",
        "November",
        "December"
      ]
    },
    "last_verified": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    }
  }
}
