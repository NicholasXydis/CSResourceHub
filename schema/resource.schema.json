{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CS Resource Hub",
  "description": "Schema for a single resource entry",
  "type": "object",
  "required": [
    "id",
    "name",
    "url",
    "description",
    "category",
    "date_added",
    "last_verified"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "url": {
      "type": "string",
      "pattern": "^https://.+"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 120
    },
    "category": {
      "type": "string",
      "enum": [
        "learning-resources",
        "interview-prep",
        "communities-clubs",
        "hackathons",
        "ctfs",
        "game-jams",
        "competitions",
        "open-source",
        "useful-repositories",
        "project-based-learning",
        "internships-fellowships",
        "recruitment-events",
        "certifications",
        "free-developer-tools"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "book",
        "course",
        "website",
        "video",
        "reference",
        "tool",
        "news",
        "guide",
        "platform",
        "club",
        "discord",
        "organization",
        "reddit",
        "project",
        "resource"
      ]
    },
    "location": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "month": {
      "type": "string",
      "enum": [
        "January",
        "February",
        "March",
        "April",
        "May",
        "June",
        "July",
        "August",
        "September",
        "October",
        "November",
        "December"
      ]
    },
    "date_added": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "last_verified": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    }
  }
}
